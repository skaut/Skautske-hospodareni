{
    "name": "skaut/skautske_hospodareni",
    "type": "project",
    "require": {
        "php": "~8.3.0",
        "ext-iconv": "*",
        "ext-simplexml": "*",
        "beberlei/assert": "^3.3",
        "beberlei/doctrineextensions": "^1.3",
        "cakephp/chronos": "^3.0",
        "composer/ca-bundle": "^1.3",
        "consistence-community/consistence": "^2.1",
        "contributte/application": "^0.5",
        "contributte/console": "^0.9",
        "contributte/console-extra": "^0.7.2",
        "contributte/forms-multiplier": "^4.0",
        "contributte/menu-control": "^3.2",
        "contributte/scheduler": "^0.7.3",
        "endroid/qr-code": "^6.0",
        "google/apiclient": "^2.15.1",
        "guzzlehttp/guzzle": "^7.8.0",
        "guzzlehttp/psr7": "^2.2.1",
        "heureka/bank-account-validator": "1.2.*",
        "http-interop/http-factory-guzzle": "^1.2",
        "ifm24/bank-statements": "^3.0",
        "illuminate/collections": "^13.20",
        "latte/latte": " ~3.0",
        "league/flysystem": "^3.21",
        "maennchen/zipstream-php": "^3.1",
        "moneyphp/money": "^4.1",
        "monolog/monolog": "^3.10",
        "mpdf/mpdf": "^8.0",
        "nesbot/carbon": "^3.10",
        "nette/application": "^3.3",
        "nette/bootstrap": "^3.3",
        "nette/caching": "^3.4",
        "nette/di": "^3.2",
        "nette/forms": "^3.3",
        "nette/http": "^3.4",
        "nette/mail": "^4.1",
        "nette/robot-loader": "^4.1",
        "nette/security": "^3.2",
        "nette/utils": "^4.1",
        "nettrine/dbal": "^0.8.0",
        "nettrine/fixtures": "^0.6.4",
        "nettrine/migrations": "^v0.8",
        "nextras/mail-panel": "^v2.5",
        "php-http/guzzle7-adapter": "^1.0",
        "phpoffice/phpspreadsheet": "^5.1",
        "ramsey/uuid": "^4.2",
        "ramsey/uuid-doctrine": "^2.1",
        "rikudou/czqrpayment": "^5.3",
        "sentry/sentry": "^4.0",
        "skaut/psr6-caching": "^0.3.0@dev",
        "skautis/skautis": "~2.3",
        "symfony/cache": "^6.4",
        "symfony/messenger": "^6.4",
        "thecodingmachine/safe": "^3.3",
        "tracy/tracy": "~2.9",
        "ublaboo/datagrid": "^7.2",
        "vlucas/phpdotenv": "^5.5",
        "warhuhn/chronos-doctrine": "v4.1.0",
        "webwingscz/fio-api-php": "6.0.0"
    },
    "require-dev": {
        "ext-pdo": "*",
        "codeception/codeception": "^5.1",
        "codeception/mockery-module": "^0.5.0",
        "codeception/module-asserts": "^3.0",
        "codeception/module-db": "^3.0",
        "codeception/module-webdriver": "^4.0",
        "contributte/codeception": "^1.6",
        "league/flysystem-memory": "^3.10",
        "php-cs-fixer/shim": "^3.89",
        "php-vcr/php-vcr": "^1.8.2",
        "phpstan/extension-installer": "^1.1",
        "phpstan/phpstan": "^1.5",
        "phpstan/phpstan-doctrine": "^1.0",
        "phpstan/phpstan-mockery": "^1.0",
        "phpstan/phpstan-nette": "^1.0",
        "roave/security-advisories": "dev-master"
    },
    "autoload": {
        "classmap": ["app/"]
    },
    "autoload-dev": {
        "classmap": ["code-quality/", "tests/_hacks"]
    },
    "config": {
        "process-timeout": 1200,
        "sort-packages": true,
        "platform": {
            "php": "8.3.0"
        },
        "allow-plugins": {
            "composer/package-versions-deprecated": true,
            "phpstan/extension-installer": true,
            "php-http/discovery": true
        }
    },
    "prefer-stable": true,
    "minimum-stability": "dev",
    "scripts": {
        "post-update-cmd": "Google_Task_Composer::cleanup",


        "main": [
            "composer install --no-interaction",
            "@static-analysis",
            "@coding-standard",
            "@schema:validate",
            "@tests"
        ],


        "tests:init": [
            "bin/console app:cache:purge || true",
            "bin/console migrations:drop-all-tables-views --no-interaction",
            "bin/console migrations:migrate --no-interaction"
        ],
        "tests:unit": "vendor/bin/codecept run unit",
        "tests:integration": "vendor/bin/codecept run integration",
        "tests:acceptance:init": [
            "bin/console app:cache:purge || true",
            "bin/console migrations:drop-all-tables-views --no-interaction",
            "bin/console migrations:migrate --no-interaction",
            "bin/console orm:generate-proxies --no-interaction"
        ],
        "tests:acceptance": [
            "@tests:acceptance:init",
            "vendor/bin/codecept run acceptance -vv"
        ],
        "tests:acceptance-ci": [
            "@tests:acceptance:init",
            "vendor/bin/codecept run acceptance --env ci -vv"
        ],
        "tests": [
            "@tests:init",
            "@tests:unit",
            "@tests:integration",
            "@tests:acceptance"
        ],
        "tests-with-coverage": "php -d zend_extension=xdebug.so -d xdebug.mode=coverage vendor/bin/codecept run unit,integration --coverage-xml",


        "static-analysis": [
            "bin/console app:cache:purge || true",
            "php -d memory_limit=2G vendor/bin/phpstan analyse -l 8 -c phpstan.neon app tests"
        ],
        "coding-standard": [
            "vendor/bin/php-cs-fixer fix --config=.php-cs-fixer.dist.php --using-cache=no"
        ],

        "coding-standard-ci": "vendor/bin/php-cs-fixer fix --config=.php-cs-fixer.dist.php --dry-run --using-cache=no",

        "lint": "vendor/bin/latte-lint app",
        "latte-lint": "@lint",

        "schema:validate": "bin/console orm:validate-schema --skip-sync",
        "proxies:generate": "bin/console orm:generate-proxies --no-interaction",

        "validate-mapping": [
            "sh code-quality/validate-mapping.sh"
        ],


        "fix": [
            "@lint",
            "@coding-standard",
            "@static-analysis"
        ],
        "app-init": [
            "composer install --no-interaction",
            "[ -f .env.local ] || cp .env.local.example .env.local",
            "yarn install",
            "bash -lc 'mkdir -p log temp/cache temp/sessions temp/mail-panel-latte temp/mail-panel-mails temp/mpdf www/webtemp && rm -rf temp/cache/* temp/sessions/* temp/mail-panel-latte/* temp/mail-panel-mails/* temp/mpdf/* www/webtemp/* frontend/.cache node_modules/.cache && rm -f temp/.phpcs-cache temp/vite-dev-server.log www/js/app.min.js www/js/app.min.js.LICENSE.txt www/css/app.css'",
            "bin/console migrations:drop-all-tables-views --force --no-interaction",
            "bin/console migrations:migrate --no-interaction",
            "yarn build"
        ],
        "diff": [
            "console doctrine:cache:clear",
            "console migrations:diff --no-interaction",
            "console migrations:migrate --no-interaction"
        ]
    },
    "extra": {
        "google/apiclient-services": [
            "Gmail",
            "Oauth2"
        ]
    }
}
