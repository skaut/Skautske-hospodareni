services:
    - App\Model\Infrastructure\Repositories\Cashbook\CashbookRepository
    - class: App\Model\Cashbook\Handlers\Cashbook\MoveChitsToDifferentCashbookHandler
      tags:
          messenger.messageHandler:
              bus: commandBus
    - class: App\Model\Cashbook\Handlers\Cashbook\AddChitScanHandler
      tags:
          messenger.messageHandler:
              bus: commandBus
    - App\Model\Infrastructure\Services\Common\FlysystemScanStorage
    - League\Flysystem\Filesystem(League\Flysystem\InMemory\InMemoryFilesystemAdapter())

includes:
    - ../../config/doctrine.neon
