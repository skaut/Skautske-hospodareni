
services:
    - App\Model\Infrastructure\Repositories\Payment\BankAccountRepository
    - App\Model\Infrastructure\Repositories\Payment\PaymentRepository
    - App\Model\Infrastructure\Repositories\Payment\GroupRepository
    - App\Model\Skautis\Payment\MemberEmailRepository
    - App\Model\Skautis\ParticipantRepository
    - App\Model\Infrastructure\Repositories\Participant\PaymentRepository
    - App\Model\Invoice\Repository\InvoiceRepository
    - App\Model\Common\Services\NotificationsCollector
    - App\Model\Payment\Services\VariableSymbolCollisionChecker
    - GuzzleHttp\Client

    - Stubs\Skautis
    - App\Model\Payment\UserRepositoryStub
    - Stubs\BankAccountAccessCheckerStub
    - Stubs\OAuthsAccessCheckerStub
    - App\Model\Payment\PaymentService
    - Stubs\GoogleRepositoryStub
    - App\Model\Google\GoogleService('', '')

    - App\Model\Mail\MailerFactory(App\Model\Payment\NullMailer(), false)
    - App\Model\Services\TemplateFactory
    - App\Model\Payment\MailingService

    - class: App\Model\Payment\Handlers\Payment\CreatePaymentHandler
      tags:
          messenger.messageHandler:
              bus: commandBus

    - class: App\Model\Payment\Subscribers\PaymentMailSubscriber
      tags:
          messenger.messageHandler:
              bus: eventBus
includes:
    - ../../config/doctrine.neon

extensions:
    latte: Nette\Bridges\ApplicationDI\LatteExtension(%tempDir%, true)
