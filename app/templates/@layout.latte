<!doctype html>
<html lang="cs">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">
    <meta name="description" content="">
    <meta name="author" content="">
    <link rel="icon" type="image/svg+xml" href="/images/skaut-logo.svg">

    <script n:syntax="off">
        if ("theme" in localStorage) {
            document.documentElement.setAttribute("data-bs-theme", localStorage.theme);
        } else if (window.matchMedia("(prefers-color-scheme: dark)").matches) {
            document.documentElement.setAttribute("data-bs-theme", "dark");
        } else {
            document.documentElement.setAttribute("data-bs-theme", "light");
        }
    </script>

    {if $productionMode}
        <script n:syntax="off">
            ga = function (){ga.q.push(arguments)};
            ga.q = [];
            ga.l = +new Date;
            ga('create', 'UA-50892244-1', 'auto');
            ga('send', 'pageview');
        </script>
        <script src="https://www.google-analytics.com/analytics.js" async defer></script>
    {/if}

    <title>{block #title|stripHtml|trim}Skautské hospodaření{/block}</title>

    <link rel="stylesheet" href="/css/app.css?{md5_file($wwwDir . '/css/app.css')}">
</head>

<body class="app-shell" data-page-help-expanded="{$showPageHelp ? 'true' : 'false'}">
<div class="page">

    <nav n:class="navbar, navbar-expand-lg, navbar-light, site-header, sticky-top, $testBackground ? 'navbar--' . $environmentColor">
        <div class="container-xl">
            {* ── Brand ── *}
            {if $user->isLoggedIn()}
                <a class="navbar-brand" n:href=":Dashboard:default">
                    {if $testBackground}
                        <span class="navbar-test-badge" title="{$environmentLabel}" data-test="test-server-badge">
                            <i class="fas fa-flask" aria-hidden="true"></i>
                            <span class="visually-hidden">{$environmentLabel}</span>
                        </span>
                    {else}
                        <img src="/images/skaut-logo.svg" class="navbar-brand-icon" alt="" aria-hidden="true">
                    {/if}
                    <span class="navbar-brand-label">Hospodaření</span>
                </a>
            {else}
                <a class="navbar-brand" n:href=":Default:">
                    {if $testBackground}
                        <span class="navbar-test-badge" title="{$environmentLabel}" data-test="test-server-badge">
                            <i class="fas fa-flask" aria-hidden="true"></i>
                            <span class="visually-hidden">{$environmentLabel}</span>
                        </span>
                    {else}
                        <img src="/images/skaut-logo.svg" class="navbar-brand-icon" alt="" aria-hidden="true">
                    {/if}
                    <span class="navbar-brand-label">Hospodaření</span>
                </a>
            {/if}

            {* ── Hamburger toggler (mobile only) ── *}
            <button class="navbar-toggler ms-auto" type="button" data-bs-toggle="collapse" data-bs-target="#navbarMain"
                    aria-controls="navbarMain" aria-expanded="false" aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
            </button>

            {* ── Collapsible area ── *}
            <div class="collapse navbar-collapse" id="navbarMain">
                <ul class="navbar-nav me-auto">
                    {if $user->isLoggedIn()}
                        {control mainMenu}
                    {else}
                        <li n:class="nav-item, $presenter->isLinkCurrent(':Default:about') ? active">
                            <a class="nav-link public-nav-link" n:href=":Default:about">O projektu</a>
                        </li>
                    {/if}
                </ul>
                <div class="site-header-actions d-flex align-items-center gap-2 my-2 my-lg-0">
                    {control darkModeToggle}
                    {if $user->isLoggedIn()}
                        <span id="timer" class="w-auto small p-1 rounded text-nowrap">
                            <i class="far fa-clock"></i>
                            <span id="timer-minutes"></span>
                        </span>
                    {/if}
                    {control loginPanel}
                </div>
            </div>
        </div>
    </nav>

    <nav n:class="navbar, navbar-expand-sm, navbar-light, submenu, site-submenu" n:ifcontent>
        <div class="container-xl" n:ifcontent>
            {block #subMenu}
                {if $module === 'Admin'}{control adminMenu}
                {elseif $module === 'Travel'}{control travelMenu}
                {elseif $module === 'Payments'}{control paymentsMenu}
                {elseif $module === 'Settings'}{control settingsMenu}{/if}
            {/block}
        </div>
    </nav>

    <div class="page-wrapper">
    <main role="main" class="container-xl shell-main page-body">
        {snippet flash}
            {foreach $flashes as $flash}
                {var $flashType = $flash->type === 'error' ? 'danger' : $flash->type}
                <div class="alert alert-{$flashType} flash-message alert-dismissible fade show" role="alert">
                    <span class="flash-message__icon" aria-hidden="true">
                        {if $flashType === 'success'}
                            <i class="fi fi-rr-check-circle"></i>
                        {elseif $flashType === 'danger'}
                            <i class="fi fi-rr-cross-circle"></i>
                        {elseif $flashType === 'warning'}
                            <i class="fi fi-rr-triangle-warning"></i>
                        {elseif $flashType === 'info'}
                            <i class="fi fi-rr-info"></i>
                        {else}
                            <i class="fi fi-rr-bell"></i>
                        {/if}
                    </span>
                    <div class="flash-message__content">
                        {if strpos($flash->message, 'html: ') === 0}
                            {$flash->message|substr:6|noescape}
                        {else}
                            {$flash->message}
                        {/if}
                    </div>
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Zavřít"></button>
                </div>
            {/foreach}
        {/snippet}

        {include #content}
    </main>

    <footer class="site-footer" id="footer" data-test="site-footer">
        <div class="container-xl site-footer__inner">
            <div class="site-footer__brand">
                <strong class="site-footer__title">Skautské hospodaření</strong>
                <p class="site-footer__text">
                    Jedno místo pro finance jednotky, akce, tábory, cesťáky i platby napojené na reálný provoz jednotky.
                </p>
            </div>

            <nav class="site-footer__nav" aria-label="Patička webu">
                <a n:href=":BugReport:default, url => $currentUrl" class="site-footer__link" data-test="footer-bug-report-link">
                    <i class="fi fi-rr-bug" aria-hidden="true"></i>
                    <span>Nahlásit problém</span>
                </a>
                <a n:href=":Default:about" class="site-footer__link">O projektu</a>
                <a n:href=":Default:reinforcement" class="site-footer__link">Posily</a>
                <a href="https://github.com/skaut/Skautske-hospodareni/graphs/contributors" class="site-footer__link">Autoři</a>
                <a href="https://github.com/skaut/Skautske-hospodareni" class="site-footer__link">
                    <i class="fab fa-github" aria-hidden="true"></i>
                    <span>Pošli PR</span>
                </a>
                <a href="https://headwayapp.co/skautske-hospodareni-changelog" target="_blank" rel="noopener noreferrer" class="site-footer__link">
                    Changelog
                </a>
            </nav>
        </div>
    </footer>
    </div>
    {var $jsBundle = '/js/app.min.js'}
    <script type="text/javascript" src="{$jsBundle}?{md5_file($wwwDir . '/' . $jsBundle)}"></script>
</div>
</body>
</html>
