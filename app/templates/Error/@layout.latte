<!doctype html>
<html lang="cs">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <meta name="robots" content="{$robots}" n:ifset="$robots">
    <meta name="theme-color" content="#4d8746">
    <link rel="icon" type="image/svg+xml" href="/images/skaut-logo.svg">
    <link rel="stylesheet" href="/css/app.css">
    <title>{block #title|stripHtml|trim}Chyba – Skautské hospodaření{/block}</title>
</head>
<body class="app-shell">
    <main class="container-xl shell-main d-flex align-items-center justify-content-center min-vh-100">
        <div class="card error-card text-center w-100">
            <div class="card-body p-4 p-md-5">
                {include #content}
            </div>
        </div>
    </main>
</body>
</html>
