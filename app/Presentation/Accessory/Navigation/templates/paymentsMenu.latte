{var $branch = $menu->findActiveItem()}
{var $items = $branch !== null ? array_filter($branch->getVisibleItemsOnMenu(), fn ($item) => $item->isAllowed()) : []}
{if $items !== []}
    <ul class="navbar-nav me-auto" data-test="payments-submenu">
        <li n:foreach="$items as $item" n:class="nav-item, $item->isActive() ? active">
            <a href="{$item->getRealLink()}" class="nav-link" n:attr="data-test => $item->getData('test')">
                <i n:if="$item->hasData('icon')" class="{$item->getData('icon')}" aria-hidden="true"></i>
                {$item->getRealTitle()}
            </a>
        </li>
    </ul>
{/if}
