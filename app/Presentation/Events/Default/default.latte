
{block #content}
<div class="d-grid gap-3 mt-4" data-test="events-default-page">
    <div class="card shadow-sm mb-4">
        <div class="card-body">
            <h1 n:inner-block="title" class="h3 mb-2">Seznam akcí</h1>
            <p class="text-body-secondary mb-0">Přehled všech akcí, jejich stavu a rychlý vstup do návazných agend.</p>
        </div>
    </div>

    {control grid}
    {control exportDialog}
</div>
{/block}
