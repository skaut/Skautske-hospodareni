{block #content}
<div data-test="payment-group-form-page">
    <div class="card shadow-sm mb-4">
        <div class="card-body">
            <h1 n:inner-block="title" class="h3 mb-2">Editace skupiny: {$group->getName()}</h1>
            <div class="d-flex flex-wrap gap-2">
                <a n:href=":Payments:Payment:default $group->id" class="btn btn-outline-secondary btn-sm">
                    <i class="fi fi-rr-arrow-left" aria-hidden="true"></i>
                    Zpět na {$group->name}
                </a>
            </div>
        </div>
    </div>

    <div class="card shadow-sm">
        <div class="card-body">
            {control editGroupForm}
        </div>
    </div>
</div>
