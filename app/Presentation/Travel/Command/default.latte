{block #content}
<div data-test="travel-command-form-page">
    <div class="card shadow-sm mb-4">
        <div class="card-body">
            <h1 class="h3 mb-2" n:inner-block="title">Založit cestovní příkaz</h1>
            <div class="d-flex align-items-start gap-2 bg-body-tertiary rounded-3 p-3">
                <i class="fi fi-rr-info text-primary mt-1 flex-shrink-0" aria-hidden="true"></i>
                <span class="text-body-secondary">Vyplňte údaje nového cestovního příkazu. Po uložení bude možné přidat jednotlivé cesty.</span>
            </div>
        </div>
    </div>

    <div class="row justify-content-center">
        <div class="col-8">
            <div class="card shadow-sm">
                <div class="card-body">
                    <strong>Údaje příkazu</strong>
                    <div class="mt-3">
                        {control form}
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
{/block}
