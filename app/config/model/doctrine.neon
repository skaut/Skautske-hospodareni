parameters:
    mappingDir: %appDir%/model/Infrastructure/mapping
    domainModelDir: %appDir%/model
    cacheDir: %tempDir%/cache

extensions:
    migrations: Nettrine\Migrations\DI\MigrationsExtension
    dbal: Nettrine\DBAL\DI\DbalExtension
    psr6: Contributte\Psr6\DI\Psr6CachingExtension

migrations:
    directory: %appDir%/../migrations
    versionsOrganization: year

dbal:
    debug:
        panel: %debugMode%

    configuration:
        resultCache: Doctrine\Common\Cache\Psr6\DoctrineProvider::wrap(Symfony\Component\Cache\Adapter\ArrayAdapter())

    connection:
        host: %database.host%
        user: %database.user%
        password: %database.password%
        dbname: %database.name%
        serverVersion: 8.0
        driver: pdo_mysql
        charset: utf8mb4
        default_table_options:
          charset: utf8mb4
          collate: utf8mb4_czech_ci

        typesMapping:
            enum: string
            set: string
            bigint: int64

        types:
            string_enum:
                class: App\Model\Infrastructure\Types\StringEnumType
                commented: true
            int64:
                class: App\Model\Infrastructure\Types\Int64Type
            payment_state:
                class: App\Model\Infrastructure\Types\PaymentStateType
                commented: true
            payment_email_type:
                class: App\Model\Infrastructure\Types\PaymentEmailTypeType
                commented: true
            payment_group_type:
                class: App\Model\Infrastructure\Types\PaymentGroupTypeType
                commented: true
            log_type:
                class: App\Model\Infrastructure\Types\LogTypeType
                commented: true
            travel_transport_type:
                class: App\Model\Infrastructure\Types\TravelTransportTypeType
                commented: true
            cashbook_operation:
                class: App\Model\Infrastructure\Types\CashbookOperationType
                commented: true
            cashbook_type:
                class: App\Model\Infrastructure\Types\CashbookTypeType
                commented: true
            cashbook_object_type:
                class: App\Model\Infrastructure\Types\CashbookObjectTypeType
                commented: true
            chit_payment_method:
                class: App\Model\Infrastructure\Types\ChitPaymentMethodType
                commented: true
            participant_event_type:
                class: App\Model\Infrastructure\Types\ParticipantEventTypeType
                commented: true
            money:
                class: App\Model\Infrastructure\Types\MoneyType
                commented: true
            variable_symbol:
                class: App\Model\Infrastructure\Types\VariableSymbolType
                commented: true
            chit_number:
                class: App\Model\Infrastructure\Types\ChitNumberType
                commented: true
            recipient:
                class: App\Model\Infrastructure\Types\RecipientType
                commented: true
            chronos_date:
                class: Warhuhn\Doctrine\DBAL\Types\ChronosDateType
                commented: true
            cashbook_id:
                class: App\Model\Infrastructure\Types\CashbookIdType
                commented: true
            unit_id:
                class: App\Model\Infrastructure\Types\UnitIdType
                commented: true
            payment_id:
                class: App\Model\Infrastructure\Types\PaymentIdType
                commented: true
            file_path:
                class: App\Model\Infrastructure\Types\FilePathType
                commented: true
            oauth_id:
                class: App\Model\Infrastructure\Types\OAuthIdType
                commented: true
            transport_types:
                class: App\Model\Infrastructure\Types\TransportTypeListType
                commented: true
            email_address:
                class: App\Model\Infrastructure\Types\EmailAddressType
                commented: true
            skautis_event_id:
                class: App\Model\Infrastructure\Types\SkautisEventIdType
                commented: true
            skautis_education_id:
                class: App\Model\Infrastructure\Types\SkautisEducationIdType
                commented: true
            skautis_camp_id:
                class: App\Model\Infrastructure\Types\SkautisCampIdType
                commented: true
            big_decimal:
                class: App\Model\Infrastructure\Types\BigDecimalType
                commented: true
            carbon_timestamp_immutable_ms:
                class: Extension\Doctrine\Types\CarbonTimestampImmutableMsType
                commented: true
            uuid_binary: Ramsey\Uuid\Doctrine\UuidBinaryType

services:
  # ── EntityManager z vaší továrny ──────────────────────────────────────────────
  doctrine.entityManagerFactory:
    factory: App\Model\Infrastructure\EntityManagerFactory(%debugMode%, %cacheDir%)

  doctrine.entityManager:
    factory: [@doctrine.entityManagerFactory, create]
    type: Doctrine\ORM\EntityManager

  # ── ManagerRegistry (autowiring přes type) ───────────────────────────────────
  doctrine.managerRegistry:
    factory: Infrastructure\Doctrine\NetteManagerRegistry(
      @doctrine.entityManager,
      @dbal.connection
    )
    type: Doctrine\Persistence\ManagerRegistry

  # ── CLI providers (ORM/DBAL) ─────────────────────────────────────────────────
  doctrine.entityManagerProvider:
    factory: Doctrine\ORM\Tools\Console\EntityManagerProvider\SingleManagerProvider(
      @doctrine.entityManager
    )

  doctrine.connectionProvider:
    factory: Doctrine\DBAL\Tools\Console\ConnectionProvider\SingleConnectionProvider(
      @dbal.connection
    )

  # ── Doctrine ORM/DBAL příkazy registrované s providers ───────────────────────
  doctrine.orm.command.validate_schema:
    factory: Doctrine\ORM\Tools\Console\Command\ValidateSchemaCommand(
      @doctrine.entityManagerProvider
    )
    tags: { console.command: orm:validate-schema }

  doctrine.orm.command.generate_proxies:
    factory: Doctrine\ORM\Tools\Console\Command\GenerateProxiesCommand(
      @doctrine.entityManagerProvider
    )
    tags: { console.command: orm:generate-proxies }
    # Pozn.: v ORM 3 deprecated – až přejdete, klidně odstranit.

  doctrine.orm.command.schema_update:
    factory: Doctrine\ORM\Tools\Console\Command\SchemaTool\UpdateCommand(
      @doctrine.entityManagerProvider
    )
    tags: { console.command: orm:schema-tool:update }

  doctrine.orm.command.schema_create:
    factory: Doctrine\ORM\Tools\Console\Command\SchemaTool\CreateCommand(
      @doctrine.entityManagerProvider
    )
    tags: { console.command: orm:schema-tool:create }

  doctrine.orm.command.schema_drop:
    factory: Doctrine\ORM\Tools\Console\Command\SchemaTool\DropCommand(
      @doctrine.entityManagerProvider
    )
    tags: { console.command: orm:schema-tool:drop }

  doctrine.dbal.command.run_sql:
    factory: Doctrine\DBAL\Tools\Console\Command\RunSqlCommand(
      @doctrine.connectionProvider
    )
    tags: { console.command: dbal:run-sql }

decorator:
    Doctrine\Migrations\Configuration\Configuration:
        setup:
            - setCheckDatabasePlatform(false)
