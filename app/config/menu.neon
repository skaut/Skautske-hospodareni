menu:
    main:
        authorizator: @App\Presentation\Accessory\Navigation\NavigationAuthorizator
        templates:
            menu: %appDir%/Presentation/Accessory/Navigation/templates/mainMenu.latte
        items:
            dashboard:
                title: Přehled
                action: 'Dashboard:default'
                include:
                    - '^Dashboard:.*$'
                data:
                    test: global-nav-dashboard
                    icon: fi fi-rr-apps
            events:
                title: Akce
                action: 'Events:Default:default'
                include:
                    - '^Events:.*$'
                data:
                    test: global-nav-events
                    icon: fi fi-rr-circle-calendar
            camps:
                title: Tábory
                action: 'Camps:Default:default'
                include:
                    - '^Camps:.*$'
                data:
                    test: global-nav-camps
                    icon: fi fi-rs-tents
            education:
                title: Vzdělávačky
                action: 'Education:Default:default'
                include:
                    - '^Education:.*$'
                data:
                    test: global-nav-education
                    icon: fi fi-rs-user-graduate
            travel:
                title: Cesťáky
                action: 'Travel:Default:default'
                include:
                    - '^Travel:.*$'
                data:
                    test: global-nav-travel
                    icon: fi fi-rr-road
            unit:
                title: Jednotka
                action: 'Unit:Cashbook:default'
                include:
                    - '^Unit:.*$'
                data:
                    test: global-nav-unit
                    icon: fi fi-rs-users
            payments:
                title: Platby
                action: 'Payments:Dashboard:default'
                include:
                    - '^Payments:.*$'
                data:
                    test: global-nav-payments
                    icon: fi fi-rr-coins
            settings:
                title: Nastavení
                action: 'Settings:Default:default'
                include:
                    - '^Settings:.*$'
                data:
                    test: utility-nav-settings
                    icon: fi fi-rr-settings
            admin:
                title: Administrace
                action: 'Admin:Default:default'
                include:
                    - '^Admin:.*$'
                data:
                    test: utility-nav-admin
                    icon: fi fi-rr-shield-check
                    requiresAdmin: true

    payments:
        authorizator: @App\Presentation\Accessory\Navigation\NavigationAuthorizator
        linkGenerator: @App\Presentation\Accessory\Navigation\PreservingLinkGenerator
        templates:
            menu: %appDir%/Presentation/Accessory/Navigation/templates/subMenu.latte
        items:
            overview:
                title: Přehled
                action: 'Payments:Dashboard:default'
                include:
                    - '^Payments:Dashboard:.*$'
                data:
                    test: payment-nav-overview
                    icon: fi fi-rr-apps
                    preserveParameters:
                        jednotka: unitId
                        rok: year
            groups:
                title: Platební skupiny
                action: 'Payments:GroupList:default'
                include:
                    - '^Payments:(GroupList|Group|Payment|Participants|People|Repayment|Journal|CampAddParticipants|CampCreateGroup|CampSelectForGroup|EventAddParticipants|EventCreateGroup|EventSelectForGroup|EducationAddParticipants|EducationCreateGroup|EducationSelectForGroup|RegistrationAddMembers|RegistrationCreateGroup|RegistrationJournal):.*$'
                data:
                    test: payment-nav-groups
                    icon: far fa-list-alt
                    preserveParameters:
                        jednotka: unitId
                        rok: year
            invoices:
                title: Faktury
                action: 'Payments:InvoiceList:default'
                include:
                    - '^Payments:(InvoiceList|InvoiceSequence|InvoiceSequenceList):.*$'
                data:
                    test: payment-nav-invoices
                    icon: fas fa-file-invoice-dollar
                    requiresInvoiceAccess: true
                    preserveParameters:
                        jednotka: unitId
                        rok: year
    settings:
        authorizator: @App\Presentation\Accessory\Navigation\NavigationAuthorizator
        linkGenerator: @App\Presentation\Accessory\Navigation\PreservingLinkGenerator
        templates:
            menu: %appDir%/Presentation/Accessory/Navigation/templates/subMenu.latte
        items:
            overview:
                title: Přehled
                action: 'Settings:Default:default'
                include:
                    - '^Settings:Default:.*$'
                data:
                    test: settings-subnav-overview
                    icon: fi fi-rr-apps
                    preserveParameters:
                        jednotka: unitId
                        rok: year
            user:
                title: Uživatel
                action: 'Settings:User:default'
                include:
                    - '^Settings:User:.*$'
                data:
                    test: settings-subnav-user
                    icon: fi fi-rr-user
                    preserveParameters:
                        jednotka: unitId
            bankAccounts:
                title: Bankovní účty
                action: 'Settings:BankAccounts:default'
                include:
                    - '^Settings:BankAccounts:.*$'
                data:
                    test: settings-subnav-bank-accounts
                    icon: fi fi-rr-bank
                    preserveParameters:
                        jednotka: unitId
                        rok: year
            mails:
                title: E-maily
                action: 'Settings:Mails:default'
                include:
                    - '^Settings:Mails:.*$'
                data:
                    test: settings-subnav-mails
                    icon: fi fi-rr-envelope
                    preserveParameters:
                        jednotka: unitId
                        rok: year
            invoices:
                title: Faktury
                action: 'Settings:Invoices:default'
                include:
                    - '^Settings:Invoices:.*$'
                data:
                    test: settings-subnav-invoices
                    icon: fi fi-rr-file-invoice
                    requiresInvoiceAccess: true
                    preserveParameters:
                        jednotka: unitId
                        rok: year
            automation:
                title: Automatizace
                action: 'Settings:Automation:default'
                include:
                    - '^Settings:Automation:.*$'
                data:
                    test: settings-subnav-automation
                    icon: fi fi-rr-settings-sliders
                    preserveParameters:
                        jednotka: unitId
                        rok: year

    admin:
        authorizator: @App\Presentation\Accessory\Navigation\NavigationAuthorizator
        templates:
            menu: %appDir%/Presentation/Accessory/Navigation/templates/subMenu.latte
        items:
            overview:
                title: Přehled
                action: 'Admin:Default:default'
                include:
                    - '^Admin:Default:.*$'
                data:
                    test: admin-nav-overview
                    icon: fi fi-rr-apps
            users:
                title: Uživatelé
                action: 'Admin:Users:default'
                include:
                    - '^Admin:Users:.*$'
                data:
                    test: admin-nav-users
                    icon: fi fi-rr-users-alt
            statistics:
                title: Statistiky
                action: 'Admin:Statistics:default'
                include:
                    - '^Admin:Statistics:.*$'
                data:
                    test: admin-nav-statistics
                    icon: fi fi-rr-chart-pie
            bugReports:
                title: Hlášení chyb
                action: 'Admin:BugReports:default'
                include:
                    - '^Admin:BugReports:.*$'
                data:
                    test: admin-nav-bug-reports
                    icon: fi fi-rr-bug
            invoiceAccess:
                title: Fakturace
                action: 'Admin:InvoiceAccess:default'
                include:
                    - '^Admin:InvoiceAccess:.*$'
                data:
                    test: admin-nav-invoice-access
                    icon: fi fi-rr-lock

    travel:
        authorizator: @App\Presentation\Accessory\Navigation\NavigationAuthorizator
        templates:
            menu: %appDir%/Presentation/Accessory/Navigation/templates/subMenu.latte
        items:
            commands:
                title: Cestovní příkazy
                action: 'Travel:Default:default'
                include:
                    - '^Travel:Default:.*$'
                data:
                    test: travel-subnav-commands
                    icon: fas fa-route
            vehicles:
                title: Vozidla
                action: 'Travel:VehicleList:default'
                include:
                    - '^Travel:(VehicleList|Vehicle):.*$'
                data:
                    test: travel-subnav-vehicles
                    icon: fas fa-car
            contracts:
                title: Smlouvy
                action: 'Travel:Contract:default'
                include:
                    - '^Travel:Contract:.*$'
                data:
                    test: travel-subnav-contracts
                    icon: fas fa-file-contract
