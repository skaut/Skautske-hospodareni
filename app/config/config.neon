includes:
    - application.neon
    - extensions.neon
    - services.neon
    - skautis.neon
    - logging.neon
    - scheduler.neon
    - menu.neon
    - model/doctrine.neon
    - sentry.neon

parameters:
    uploadDirectory: %appDir%/../uploads
    testBackground: false
    adminAllowedUserIds: []

php:
    date.timezone: Europe/Prague

session:
    autoStart: smart
    expiration: "+ 3 days"
