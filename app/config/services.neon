search:
    command handlers:
        in: %appDir%
        classes:
            - App\Model\**\Handlers\**Handler
        tags:
            messenger.messageHandler:
                bus: commandBus

    query handlers:
        in: %appDir%
        classes:
            - App\Model\Infrastructure\**\ReadModel\**Handler
            - App\Model\**\ReadModel\**Handler
        tags:
            messenger.messageHandler:
                bus: queryBus

    event subscribers:
        in: %appDir%
        classes:
            - App\Model\*\Subscribers\*Subscriber
        tags:
            messenger.messageHandler:
                bus: eventBus

    UI control factories:
        in: %appDir%
        classes:
            - App\Components\**\I*Factory
            - App\Presentation\**\I*Factory

    services:
        in: %appDir%
        classes:
            # Infrastructure repositories (still at old namespace)
            - App\Model\Infrastructure\Repositories\**Repository
            - App\Model\Infrastructure\Services\**

            # Refactored infrastructure
            - App\Model\Infrastructure\Repository\**
            - App\Model\Infrastructure\Manager\**

            # Refactored domains (generic)
            - App\Model\**Service
            - App\Model\*\Services\**
            - App\Model\*\Repository\**
            - App\Model\*\Manager\**
            - App\Model\*\Repositories\*Repository

            # Skautis communication
            - App\Model\Skautis\**

            # Top-level services
            - App\Model\Services\**

        exclude:
            classes:
                - App\Model\Infrastructure\Skautis\LazyWebService
                - App\Model\Infrastructure\Skautis\RetryingWebService
                - App\Model\Skautis\WebserviceFactory
                - App\Model\Skautis\ReadModel\Queries\**
                - App\Model\Event\EventService
                - App\Model\Chit\ChitService
                - App\Model\Participant\ParticipantService
                - App\Model\Admin\Services\AdminAccessChecker
                - App\Model\BugReport\BugReportNotificationService
                - App\Model\BugReport\BugReportService
                - App\Model\BugReport\GitHubIssueService
                - App\Model\Invoice\InvoiceAccessChecker
                - App\Model\Bank\Services\BankAccountPairingRunResult
                - App\Model\Bank\Services\CiFioTokenValidator
                - App\Model\Bank\Services\FioTokenValidator
                - App\Model\Bank\Services\ParsedGpcFile

services:
    # Messenger buses
    - App\Model\Common\Services\MessengerCommandBus(@messenger.commandBus.bus)
    - App\Model\Common\Services\MessengerQueryBus(@messenger.queryBus.bus)
    - App\Model\Common\Services\MessengerEventBus(@messenger.eventBus.bus)

    # Auth
    - factory: App\Model\Admin\Services\AdminAccessChecker(@Nette\Security\User, @App\Model\User\Repository\AdminUserRepository, %adminAllowedUserIds%)
    - factory: App\Model\Invoice\InvoiceAccessChecker(@Nette\Security\User, @App\Model\User\Repository\InvoiceAccessUserRepository, %invoiceAccessAllowedUserIds%)
    - App\Model\Auth\CompositeAuthorizator(@skautisAuthorizator, @App\Model\Admin\Services\AdminAccessChecker, @App\Model\Invoice\InvoiceAccessChecker)
    - App\Presentation\Accessory\Navigation\NavigationAuthorizator
    - App\Presentation\Accessory\Navigation\PreservingLinkGenerator

    # Console commands
    - Console\MigrationsDropCommand
    app.cachePurge:
        factory: App\Console\CachePurgeCommand([
            %tempDir%/cache
        ])
        tags: [contributte.console.command]
    fioTokenValidator:
        factory: App\Model\Bank\Services\FioTokenValidator
    fioTokenValidatorInterface:
        type: App\Model\Bank\Services\FioTokenValidatorInterface
        factory: @fioTokenValidator
    console.doctrineCacheClear:
        factory: App\Console\DoctrineCacheClearCommand(
            @Contributte\Psr6\ICachePoolFactory,
            @cache.storage,
            %tempDir%
        )
        tags: [contributte.console.command]

    # App
    - App\Context(
          appDir: %appDir%
          wwwDir: %wwwDir%
          productionMode: %productionMode%
          showTestBackground: %testBackground%
          environmentLabel: %environmentLabel%
          environmentColor: %environmentColor%
      )
    - App\RouterFactory
    router: @App\RouterFactory::createRouter

    # Grids
    - App\Components\Grids\GridFactory

    # Payment
    group:
        factory: App\Model\Payment\GroupService
    - App\Model\Payment\PaymentService
    - App\Model\Payment\BankAccountService(fioCache: @fio.cache)
    - App\Components\Payment\PairButtonBankAccountSupport
    - App\Components\Payment\BankAccountDetail\BankAccountDetailViewFactory
    - App\Components\Payment\BankAccountDetail\BankAccountManualPairingService

    # PDF & Excel
    - App\Model\Services\PdfRenderer(%gotenbergUrl%, %appDir%/../www, GuzzleHttp\Client({ timeout: 60 }))
    - App\Model\Cashbook\ReadModel\SpreadsheetFactory
    - App\Model\Cashbook\ReadModel\QueryHandlers\Pdf\SheetChitsGenerator

    # Google
    - App\Model\Google\GoogleService(%google.credentials%, %google.redirectUri%)

    # FIO bank
    - GuzzleHttp\Client({ timeout: 3 })
    fio.apiClient:
        type: GuzzleHttp\Client
        factory: GuzzleHttp\Client
        arguments:
            -
                timeout: 300
                version: 1.1
                curl:
                    # CURLOPT_SSLVERSION => CURL_SSLVERSION_TLSv1_2 | CURL_SSLVERSION_MAX_TLSv1_2
                    32: 393222
                    10083: 'DEFAULT:!ECDHE:!TLSv1.3'
        autowired: false
    fio.client:
        factory: App\Model\Bank\Fio\FioClient
        autowired: false
    fio.cache: Nette\Caching\Cache
    - App\Model\Payment\Fio\CachingClientDecorator(@fio.client, @fio.cache)
    - App\Model\Bank\Fio\DownloaderFactory(@fio.apiClient)
    - App\Model\Bank\Fio\UploaderFactory(@fio.apiClient)

    # Other services
    - App\Model\Participant\ParticipantService
    - App\Model\Skautis\Factory\EventFactory
    - App\Model\Stat\StatisticsService
    - App\Model\Bank\Services\BankAccountPairingRunner

    # Flysystem
    - League\Flysystem\Filesystem(League\Flysystem\Local\LocalFilesystemAdapter(%uploadDirectory%))
    - App\Model\Infrastructure\Services\Common\FlysystemScanStorage
    - App\Model\Invoice\InvoiceImageStorage(
          filesystem: @League\Flysystem\Filesystem
          uploadDirectory: %uploadDirectory%
      )

    # Mail
    - App\Model\Mail\MailerFactory(@nette.mailer, %sendEmail%)
    - App\Model\Mail\SystemMailer(
          debugMailer: @nette.mailer
          sendEmail: %sendEmail%
          productionMode: %productionMode%
          appBaseUrl: %appBaseUrl%
      )
    - App\Model\User\InvoiceAccessNotificationService
    - App\Model\BugReport\BugReportScreenshotStorage(
          filesystem: @League\Flysystem\Filesystem
          uploadDirectory: %uploadDirectory%
      )
    - App\Model\BugReport\BugReportNotificationService(
          recipients: %errorEmails%
          appBaseUrl: %appBaseUrl%
          screenshotStorage: @App\Model\BugReport\BugReportScreenshotStorage
      )
    - App\Model\BugReport\GitHubIssueService(
          config: %githubIssues%
      )
    - App\Model\BugReport\BugReportService(appRelease: %sentry.releaseHash%)

    # Latte
    nette.latteFactory:
        setup:
            - addExtension(App\Helpers\AccountancyLatteExtension())

decorator:
    Doctrine\DBAL\Configuration:
        setup:
            - setMiddlewares([Doctrine\DBAL\Logging\Middleware(@Monolog\Logger)])
