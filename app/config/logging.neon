tracy:
    email: %errorEmails%
    # Reálné chyby (warnings, notices, type errors) zůstávají fatální. Deprecations se pouze logují,
    # aby nezhazovaly běh (typicky během přechodu na novější Nette) – nejde o skrytí, zůstávají v logu.
    strictMode: 'E_ALL & ~E_DEPRECATED & ~E_USER_DEPRECATED'
    maxDepth: 6
    maxLength: 500
    showBar: %tracyShowBar%
    bar:
        - Nextras\MailPanel\MailPanel(%tempDir%/mail-panel-latte)

services:
    # Monolog
    - factory: Monolog\Logger
      arguments:
          name: hskauting
          handlers: []
          processors:
              - App\Model\Infrastructure\Log\Monolog\UserContextProcessor()
              - App\Model\Infrastructure\Log\Monolog\FormContextProcessor()

    - App\Model\Infrastructure\Log\UserContextProvider

    # Mail panel (dev)
    nette.mailer: Nextras\MailPanel\FileMailer(%tempDir%/mail-panel-mails)

decorator:
    Monolog\Logger:
        setup:
            # NEON parses 0664 as decimal 664, which chmod interprets as octal 01230.
            # Decimal 436 is the chmod value for octal 0664.
            - pushHandler(Monolog\Handler\RotatingFileHandler(%logDir%/log.log, 90, Monolog\Logger::INFO, true, 436))
