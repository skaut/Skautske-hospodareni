<div id="bankAccountUnavailableAlert" class="alert alert-secondary small d-none">
    <strong>Bankovní párování je zatím nedostupné.</strong>
    Nejprve vyberte bankovní účet a uložte skupinu.
</div>
<div id="emailUnavailableAlert" class="alert alert-secondary small d-none">
    <strong>E-mailové šablony jsou zatím nedostupné.</strong>
    Nejprve vyberte e-mail odesílatele a uložte skupinu.
</div>
{control form}
