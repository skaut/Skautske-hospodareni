# Local overrides for development. Copy to `.env.local` only when you need
# values different from the defaults in `.env`.
APP_ENV=dev
APP_BASE_URL=http://moje-hospodareni.cz
# Default localhost SkautIS application id.
APPLICATION_ID=48104fe2-b447-47f5-9a26-051c710da74e
# Comma-separated recipients shared by server error notifications and technical error reports.
# ERROR_EMAILS=admin@example.cz

# Optional GitHub issue integration for technical error reports.
# Use a fine-grained personal access token with Issues read/write access to this repository.
# GITHUB_ISSUES_TOKEN=github_pat_...
# GITHUB_ISSUES_OWNER=skaut
# GITHUB_ISSUES_REPOSITORY=Skautske-hospodareni
# GITHUB_ISSUES_LABELS=bug,user-report

# Uncomment when you need custom local credentials or a different database host.
# DB_HOST=mysql
# DB_NAME=hskauting
# DB_USER=hskauting
# DB_PASSWORD=hskauting

# Uncomment when you want to hide Tracy bar locally.
# TRACY_SHOW_BAR=false

# Optional non-production environment marker in the top navigation.
# TEST_BACKGROUND=true
# ENVIRONMENT_LABEL=Beta server
# ENVIRONMENT_COLOR=beta

# Maintenance mode. Allowed IPs can be exact addresses or CIDR ranges.
# MAINTENANCE_MODE=false
# MAINTENANCE_ALLOWED_IPS=127.0.0.1,192.0.2.10,2001:db8::/32
# MAINTENANCE_STARTED_AT_LABEL=čtvrtek 2. 7. 2026 od 20:00
# MAINTENANCE_STARTED_AT_DATETIME=2026-07-02T20:00:00+02:00
# MAINTENANCE_ENDS_AT_LABEL=nejpozději do 7. 7. 2026
# MAINTENANCE_ENDS_AT_DATETIME=2026-07-07T23:59:59+02:00
